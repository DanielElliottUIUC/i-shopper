# ── OpenAI (direct) ──────────────────────────────────────────────────────────
# Used if Azure vars below are NOT set
OPENAI_API_KEY=

# ── Azure OpenAI (takes priority over OPENAI_API_KEY if both set) ─────────────
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=          # e.g. https://my-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o  # your deployment name
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Anthropic (direct) ────────────────────────────────────────────────────────
# Used if AWS vars below are NOT set
ANTHROPIC_API_KEY=

# ── AWS Bedrock (takes priority over ANTHROPIC_API_KEY if either auth set) ────
# Option A — Bedrock bearer token (from AWS console → Bedrock → API Keys)
AWS_BEARER_TOKEN_BEDROCK=
# Option B — IAM user credentials (from AWS console → IAM → Users → Security credentials)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=              # optional, for temporary credentials
AWS_REGION=us-east-1
BEDROCK_CLAUDE_MODEL=us.anthropic.claude-3-7-sonnet-20250219-v1:0

# ── SerpAPI ───────────────────────────────────────────────────────────────────
SERPAPI_KEY=

# ── Vercel KV (Upstash Redis) ─────────────────────────────────────────────────
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── App config ────────────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.6
